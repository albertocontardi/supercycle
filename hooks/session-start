#!/usr/bin/env bash
# SessionStart hook for SuperCycle plugin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-supercycle content
using_supercycle_content=$(cat "${PLUGIN_ROOT}/skills/using-supercycle/SKILL.md" 2>&1 || echo "Error reading using-supercycle skill")

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_supercycle_escaped=$(escape_for_json "$using_supercycle_content")

session_context="<EXTREMELY_IMPORTANT>\nYou have SuperCycle.\n\n**Below is the full content of your 'supercycle:using-supercycle' skill - your guide to using skills and closing the session loop. For all other skills, use the 'Skill' tool:**\n\n${using_supercycle_escaped}\n\n</EXTREMELY_IMPORTANT>"

# Output for Claude Code vs Cursor vs other platforms
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
